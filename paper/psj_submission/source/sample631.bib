journal = {Spectrochimica Acta Part B: Atomic Spectroscopy},
volume = {59},
number = {10},
pages = {1725-1731},
year = {2004},
note = {17th International Congress on X-Ray Optics and Microanalysis},
issn = {0584-8547},
